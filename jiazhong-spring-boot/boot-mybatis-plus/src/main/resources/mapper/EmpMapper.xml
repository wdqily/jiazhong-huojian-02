<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.jiazhong.huojian.spring.boot.mybatis.plus.mapper.EmpMapper">

    <select id="findAllEmp" resultType="com.jiazhong.huojian.spring.boot.mybatis.plus.been.Emp">
        select *
        from emp
        where state = 1
    </select>
</mapper>